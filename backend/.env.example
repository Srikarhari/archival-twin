# Archival Twin — Backend Environment Variables
# Copy this file to .env and adjust values for your environment.

# Server
HOST=0.0.0.0
PORT=8000

# Paths (relative to project root, not backend/)
# Use forward slashes even on Windows — pathlib handles conversion.
ARCHIVE_DIR=../Faces_FullArchive
LATEST_MATCH_DIR=../Latest_match
DB_PATH=./data/archive.db

# Face engine
# Options: insightface, stub
FACE_ENGINE=insightface

# InsightFace model name (downloaded automatically on first run)
INSIGHTFACE_MODEL=buffalo_l

# Detection size (width, height) — smaller = faster, less accurate
INSIGHTFACE_DET_SIZE=640,640

# Minimum face detection confidence (0.0–1.0)
MIN_DETECTION_SCORE=0.5

# CORS — allowed origins (comma-separated)
# For LAN deployment, set to the iPad's address or use *
CORS_ORIGINS=*
